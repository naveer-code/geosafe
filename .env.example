# Server Configuration
NODE_ENV=development
PORT=3000

# MongoDB Configuration
MONGO_URI=mongodb://username:password@cluster0.mongodb.net/geosafe?ssl=true&replicaSet=rs0&authSource=admin

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Security
ADMIN_SECRET_KEY=your-secret-admin-key-change-in-production

# API Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Geospatial Configuration
GEOSPATIAL_BUFFER_DISTANCE=800
